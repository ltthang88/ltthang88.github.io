---
import Nav from '../components/Nav.astro';
import '../styles/global.css';

interface Props {
  title: string;
  description?: string;
  ogImage?: string;
}

const {
  title,
  description = 'Technical blog về Kubernetes, CI/CD, Databases, Networking và Career.',
  ogImage,
} = Astro.props;

const canonicalURL = new URL(Astro.url.pathname, Astro.site);
const siteTitle = title === 'ltthang88' ? title : `${title} · ltthang88`;
---

<!doctype html>
<html lang="vi">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />

    <!-- Set theme before paint to avoid flash -->
    <script is:inline>
      (function () {
        try {
          var t = localStorage.getItem('theme');
          if (t === 'dark' || t === 'light') {
            document.documentElement.setAttribute('data-theme', t);
          }
        } catch (e) {}
      })();
    </script>

    <link rel="canonical" href={canonicalURL} />
    <meta name="description" content={description} />

    <!-- Open Graph -->
    <meta property="og:type" content="website" />
    <meta property="og:url" content={canonicalURL} />
    <meta property="og:title" content={siteTitle} />
    <meta property="og:description" content={description} />
    {ogImage && <meta property="og:image" content={ogImage} />}

    <!-- Pagefind (built after `astro build`) -->
    <link rel="stylesheet" href="/pagefind/pagefind-ui.css" />

    <title>{siteTitle}</title>
  </head>
  <body>
    <Nav />
    <main>
      <slot />
    </main>
    <footer>
      <div class="footer-inner">
        <div class="footer-prompt">
          <span class="prompt-path">~/field-notes</span>
          <span class="prompt-dollar">$</span>
          <nav class="prompt-topics">
            <a href="/category/kubernetes">kubernetes</a>
            <span class="prompt-sep">·</span>
            <a href="/category/ci-cd">ci/cd</a>
            <span class="prompt-sep">·</span>
            <a href="/category/observability">observability</a>
            <span class="prompt-sep">·</span>
            <a href="/category/platform">platform</a>
            <span class="prompt-sep">·</span>
            <a href="/category/security">security</a>
            <span class="prompt-sep">·</span>
            <a href="/category/career">career</a>
          </nav>
        </div>
        <div class="footer-status">
          <span class="status-dot" aria-hidden="true"></span>
          <span class="status-label">operational</span>
          <a href="https://github.com/ltthang88" target="_blank" rel="noopener" class="footer-gh">github ↗</a>
          <span class="footer-year">{new Date().getFullYear()}</span>
        </div>
      </div>
    </footer>
  </body>
</html>
