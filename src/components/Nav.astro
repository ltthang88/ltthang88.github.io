---
import { getCollection } from 'astro:content';
import { CATEGORIES, categoryToSlug } from '../lib/categories';

const allPosts = await getCollection('blog', ({ data }) => !data.draft);

// Count posts per category
const counts = Object.fromEntries(
  CATEGORIES.map((cat) => [
    cat,
    allPosts.filter((p) => p.data.category === cat).length,
  ])
) as Record<string, number>;

const currentPath = Astro.url.pathname;
---

<nav class="site-nav">
  <div class="nav-inner">
    <a href="/" class="nav-logo">ltthang88</a>

    <ul class="nav-links">
      {
        CATEGORIES.map((cat) => {
          const slug = categoryToSlug(cat);
          const href = `/category/${slug}/`;
          const active = currentPath.startsWith(`/category/${slug}`);
          return (
            <li>
              <a href={href} class={active ? 'active' : ''}>
                {cat}
                {counts[cat] > 0 && (
                  <span class="nav-count">{counts[cat]}</span>
                )}
              </a>
            </li>
          );
        })
      }
    </ul>

    <div class="nav-right">
      <a href="/search/" class="nav-search-btn" aria-label="Search">
        <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round">
          <circle cx="11" cy="11" r="8"/>
          <path d="m21 21-4.35-4.35"/>
        </svg>
        Search
      </a>
    </div>
  </div>
</nav>
