---
import { getCollection } from 'astro:content';
import { CATEGORIES, categoryToSlug } from '../lib/categories';

const allPosts = await getCollection('blog', ({ data }) => !data.draft);

// Count posts per category
const counts = Object.fromEntries(
  CATEGORIES.map((cat) => [
    cat,
    allPosts.filter((p) => p.data.category === cat).length,
  ])
) as Record<string, number>;

const currentPath = Astro.url.pathname;
---

<nav class="site-nav">
  <div class="nav-inner">
    <a href="/" class="nav-logo">ltthang88</a>

    <ul class="nav-links">
      {
        CATEGORIES.map((cat) => {
          const slug = categoryToSlug(cat);
          const href = `/category/${slug}/`;
          const active = currentPath.startsWith(`/category/${slug}`);
          return (
            <li>
              <a href={href} class={active ? 'active' : ''}>
                {cat}
                {counts[cat] > 0 && (
                  <span class="nav-count">{counts[cat]}</span>
                )}
              </a>
            </li>
          );
        })
      }
      <li>
        <a href="/tags/" class={currentPath.startsWith('/tag') ? 'active' : ''}>Tags</a>
      </li>
    </ul>

    <div class="nav-right">
      <button id="theme-toggle" class="nav-icon-btn" type="button" aria-label="Chuyển dark/light mode">
        <svg class="theme-icon-moon" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
          <path d="M21 12.79A9 9 0 1 1 11.21 3 7 7 0 0 0 21 12.79z"/>
        </svg>
        <svg class="theme-icon-sun" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
          <circle cx="12" cy="12" r="5"/>
          <path d="M12 1v2M12 21v2M4.22 4.22l1.42 1.42M18.36 18.36l1.42 1.42M1 12h2M21 12h2M4.22 19.78l1.42-1.42M18.36 5.64l1.42-1.42"/>
        </svg>
      </button>

      <a href="/search/" class="nav-search-btn" aria-label="Search">
        <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round">
          <circle cx="11" cy="11" r="8"/>
          <path d="m21 21-4.35-4.35"/>
        </svg>
        <span class="nav-search-label">Search</span>
      </a>
    </div>
  </div>
</nav>

<script>
  const toggle = document.getElementById('theme-toggle');
  toggle?.addEventListener('click', () => {
    const root = document.documentElement;
    const current =
      root.getAttribute('data-theme') ||
      (window.matchMedia('(prefers-color-scheme: dark)').matches ? 'dark' : 'light');
    const next = current === 'dark' ? 'light' : 'dark';
    root.setAttribute('data-theme', next);
    try {
      localStorage.setItem('theme', next);
    } catch (e) {}
  });
</script>
